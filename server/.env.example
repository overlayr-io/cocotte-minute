# Postgres (Supabase — utiliser le pooler IPv4, pas la connexion directe db.xxxxx.supabase.co
# qui ne résout plus qu'en IPv6 : incompatible avec les hébergeurs sans sortie IPv6 comme Render free tier)
# Session pooler (port 5432) ou Transaction pooler (port 6543, requiert prepare:false côté Drizzle)
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-xxxxx.pooler.supabase.com:6543/postgres

# Supabase project
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# Secret HS256 utilisé pour vérifier les JWT émis par Supabase Auth
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters

# App
PORT=3000

# Partage de recette (feature partage-recette)
# URL publique de base : sert à construire les liens de partage (/r/:token) et doit
# correspondre au domaine déclaré dans les fichiers de deep link (.well-known).
PUBLIC_BASE_URL=http://localhost:3000
# Identité app pour les universal/app links (placeholders TODO_* si absent) :
# iOS : "<TeamID>.<BundleID>", ex. ABCDE12345.com.cocotteminute.cocotteMinute
APPLE_APP_ID=TODO_TEAMID.com.cocotteminute.cocotteMinute
# Android : empreinte SHA256 du certificat de signing (keytool -list -v ...)
ANDROID_CERT_SHA256=TODO_SHA256_FINGERPRINT
