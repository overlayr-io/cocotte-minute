# Postgres (Supabase — connection string, mode "session" ou "transaction" pooler)
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Supabase project
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# Secret HS256 utilisé pour vérifier les JWT émis par Supabase Auth
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters

# App
PORT=3000
